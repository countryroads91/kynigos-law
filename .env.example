# White-paper lead capture (/api/lead → Resend email).
# Set these in Vercel: Project Settings → Environment Variables. Do NOT commit real values.

# Required to email leads. Create a free key at https://resend.com (API Keys).
RESEND_API_KEY=

# Where white-paper download leads are emailed (e.g. bayan@kynigos.law).
LEAD_NOTIFY_EMAIL=

# Optional. Default is Resend's sandbox sender, which can only deliver to your own
# verified address. To send from kynigos.law, verify the domain in Resend and set:
# LEAD_FROM_EMAIL=Kynigos Law Firm <leads@kynigos.law>
LEAD_FROM_EMAIL=
